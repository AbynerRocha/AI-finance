// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionTypes {
  BILL
  SALARY
  OTHER
}

enum WalletType {
  MAIN
  SAVINGS
  INVESTING
  OTHER
}

model User {
  id       String @unique @default(uuid())
  name     String
  email    String @unique
  password String

  createdAt DateTime?      @default(now()) @map("created_at")
  finances  Transactions[]
  accounts  Wallet[]

  accessLevel   String          @default("user")
  refreshTokens RefreshTokens[]

  @@map("tb_users")
}

model Transactions {
  id     String @unique @default(nanoid())
  User   User   @relation(fields: [userId], references: [id])
  userId String @map("finance_user_id")

  type TransactionTypes
  date DateTime         @default(now()) @map("created_at")

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  @@index([userId, date])
  @@map("tb_transactions")
}

model Wallet {
  id     String @unique @default(uuid())
  User   User   @relation(fields: [userId], references: [id])
  userId String @map("account_user_id")

  type         WalletType
  currency     String         @default("DOL") @db.Char(3)
  amountCent   BigInt         @default(0)
  createdAt    DateTime       @default(now()) @map("created_at")
  Transactions Transactions[]

  @@index([userId])
  @@map("tb_wallets")
}

model RefreshTokens {
  id Int @id @default(autoincrement())

  User      User     @relation(fields: [userId], references: [id])
  userId    String @map("user_id")
  token     String @unique
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([userId])
  @@map("tb_refresh_tokens")
}
