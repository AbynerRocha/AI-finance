generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//=========================| ENUMS |============================= 

enum TransactionTypes {
  INCOME
  EXPENSE
  TRANSFER
}

enum WalletType {
  MAIN
  SAVINGS
  INVESTING
  OTHER
}

enum CategoryType {
  INCOME
  EXPENSE
}

//=========================| MODELS |=============================

model User {
  id       String @id @unique @default(uuid())
  name     String
  email    String @unique
  password String

  createdAt DateTime? @default(now()) @map("created_at")
  accounts  Wallet[]

  accessLevel   String                   @default("user")
  refreshTokens RefreshTokens[]
  categories    TransactionsCategories[]

  @@index([id])
  @@map("tb_users")
}

model Wallet {
  id           String         @id @unique @default(uuid())
  User         User           @relation(fields: [userId], references: [id])
  userId       String         @map("account_user_id")
  name         String
  type         WalletType
  currency     String         @default("DOL") @db.Char(3)
  amountCents  BigInt         @default(0)
  createdAt    DateTime       @default(now()) @map("created_at")
  Transactions Transactions[]

  @@index([id, userId])
  @@map("tb_wallets")
}

model Transactions {
  id              String           @id @unique @default(nanoid())
  type            TransactionTypes
  date            DateTime         @default(now()) @map("created_at")
  walletId        String
  wallet          Wallet?          @relation(fields: [walletId], references: [id])
  description     String?
  amountCents     BigInt
  isPaid          Boolean
  parcel          Int?             @default(0) @db.SmallInt
  numberOfParcels Int?             @default(0) @db.SmallInt

  transactionsCategories TransactionsCategories? @relation(fields: [category], references: [id])
  category               Int?

  @@index([walletId, date])
  @@map("tb_transactions")
}

model TransactionsCategories {
  id    Int          @id @default(autoincrement())
  name  String
  type  CategoryType
  icon  String?
  color String?

  Transactions Transactions[]
  User         User           @relation(fields: [userId], references: [id])
  userId       String

  @@index([type, userId])
  @@map("tb_transctions_categories")
}

model RefreshTokens {
  id Int @id @default(autoincrement())

  User      User      @relation(fields: [userId], references: [id])
  userId    String    @map("user_id")
  token     String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([token, userId])
  @@map("tb_refresh_tokens")
}
